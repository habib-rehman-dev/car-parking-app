# Server Configuration
PORT=3001

# Database Connection
# Replace <username>, <password>, and <cluster-url> with your MongoDB Atlas details
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/Parking?appName=Cluster0

# Security & Authentication
# Generate a strong, random string for your secrets
JWT_SECRET=your_jwt_secret_key_here
COOKIE_SECRET=your_cookie_secret_key_here

# Frontend Client URL (comma-separated if multiple origins are allowed)
CLIENT_URL=http://localhost:5173